// Noble Estimator - Prisma Schema
// Foundation for Noble CRM - designed for growth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================
// ENUMS
// ========================

enum UserRole {
  OWNER
  SALES
  ESTIMATOR
  CREW_LEAD
}

enum CustomerSource {
  GBP
  REFERRAL
  ANGI
  DOOR_HANGER
  WEBSITE
  OTHER
}

enum ConstructionType {
  STUCCO
  WOOD
  HARDIE_BOARD
  BRICK
  VINYL
  ALUMINUM
  MIXED
}

enum EstimateStatus {
  DRAFT
  AI_PROCESSING
  REVIEW
  SENT
  VIEWED
  APPROVED
  DECLINED
  EXPIRED
}

enum ScopeType {
  EXTERIOR
  INTERIOR
  BOTH
}

enum LineItemCategory {
  PREP
  PAINT
  PRIMER
  TRIM
  DETAIL
  REPAIR
  MATERIAL
  OTHER
}

enum SurfaceType {
  EXTERIOR_WALL
  INTERIOR_WALL
  CEILING
  TRIM
  FASCIA
  SOFFIT
  DOOR
  GARAGE_DOOR
  FENCE
  DECK
  CABINET
  SHUTTERS
  ACCENT_WALL
  OTHER
}

enum ContractStatus {
  GENERATED
  SENT
  VIEWED
  SIGNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentTier {
  UPFRONT_CASH
  UPFRONT_CARD
  FINANCE
  PAYMENT_PLAN
}

enum PaymentType {
  DEPOSIT
  MIDPOINT
  COMPLETION
  FULL_UPFRONT
}

enum PaymentMethod {
  CASH
  CHECK
  ACH_STRIPE
  CARD_STRIPE
  KLARNA
  AFTERPAY
}

enum PaymentStatus {
  SCHEDULED
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
  REFUNDED
}

enum ReminderType {
  UPCOMING
  DUE
  OVERDUE
  FAILED
  RETRY
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageChannel {
  IMESSAGE
  RCS
  EMAIL
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum PricingCategory {
  MATERIAL
  LABOR
  MARKUP
  PAYMENT
  COVERAGE
  OTHER
}

enum ChangeOrderStatus {
  PROPOSED
  CUSTOMER_NOTIFIED
  APPROVED
  DECLINED
  COMPLETED
}

enum ApprovalMethod {
  EMAIL
  TEXT
  IN_APP_SIGNATURE
}

enum SurfaceCondition {
  GOOD
  FAIR
  POOR
}

// ========================
// MODELS
// ========================

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String?
  role         UserRole   @default(OWNER)
  passwordHash String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  estimates    Estimate[] @relation("CreatedByUser")

  @@index([email])
}

model Customer {
  id        String         @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String
  address   String?
  city      String?
  state     String?        @default("FL")
  zip       String?
  source    CustomerSource @default(OTHER)
  notes     String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  properties   Property[]
  estimates    Estimate[]
  contracts    Contract[]
  messages     Message[]
  verificationCodes CustomerVerificationCode[]

  @@index([email])
  @@index([phone])
  @@index([lastName, firstName])
}

model Property {
  id                     String           @id @default(cuid())
  customerId             String
  address                String
  city                   String           @default("Tampa")
  state                  String           @default("FL")
  zip                    String
  squareFootageInterior  Int?
  stories                Int?             @default(1)
  constructionType       ConstructionType @default(STUCCO)
  yearBuilt              Int?
  notes                  String?          @db.Text
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  customer  Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  estimates Estimate[]

  @@index([customerId])
  @@index([address])
}

model Estimate {
  id               String         @id @default(cuid())
  propertyId       String
  customerId       String
  createdById      String
  status           EstimateStatus @default(DRAFT)
  scopeType        ScopeType
  basePrice        Float?
  upfrontCashPrice Float?
  upfrontCardPrice Float?
  financePrice     Float?
  paymentPlanPrice Float?
  aiAnalysis       Json?
  humanNotes       String?        @db.Text
  scopeOfWork      String?        @db.Text
  timeline         String?
  warrantyTerms    String?        @db.Text
  viewToken        String?        @unique @default(cuid())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  sentAt           DateTime?
  viewedAt         DateTime?
  approvedAt       DateTime?

  property     Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  customer     Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy    User                  @relation("CreatedByUser", fields: [createdById], references: [id])
  lineItems    EstimateLineItem[]
  photos       EstimatePhoto[]
  measurements EstimateMeasurement[]
  contracts    Contract[]
  messages     Message[]             @relation("EstimateMessages")
  surfaces     EstimateSurface[]

  @@index([customerId])
  @@index([propertyId])
  @@index([status])
  @@index([createdById])
  @@index([viewToken])
}

model EstimateSurface {
  id          String           @id @default(cuid())
  estimateId  String
  surfaceType SurfaceType
  description String?
  condition   SurfaceCondition @default(GOOD)
  included    Boolean          @default(true)
  notes       String?          @db.Text

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model EstimateLineItem {
  id          String           @id @default(cuid())
  estimateId  String
  category    LineItemCategory
  description String
  quantity    Float
  unit        String           @default("sqft")
  unitCost    Float
  totalCost   Float
  sortOrder   Int              @default(0)

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model EstimatePhoto {
  id             String   @id @default(cuid())
  estimateId     String
  url            String
  caption        String?
  aiAnalysis     String?  @db.Text
  location       String?
  flaggedIssues  Json?
  showToCustomer Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model EstimateMeasurement {
  id               String      @id @default(cuid())
  estimateId       String
  surface          SurfaceType
  description      String?
  linearFeet       Float?
  height           Float?
  grossArea        Float?
  windowDeduction  Float?      @default(0)
  doorDeduction    Float?      @default(0)
  netPaintableArea Float?
  coatsRequired    Int         @default(2)
  notes            String?     @db.Text

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model Contract {
  id                     String         @id @default(cuid())
  estimateId             String
  customerId             String
  status                 ContractStatus @default(GENERATED)
  documentUrl            String?
  contractSnapshot       Json?
  signedAt               DateTime?
  signatureData          String?        @db.Text
  signerIpAddress        String?
  signerName             String?
  paymentTier            PaymentTier
  stripeCustomerId       String?
  stripePaymentMethodId  String?
  depositAmount          Float?
  midpointAmount         Float?
  completionAmount       Float?
  totalAmount            Float
  termsAccepted          Boolean        @default(false)
  autoChargeAuthorized   Boolean        @default(false)
  scheduledStartDate     DateTime?
  completedAt            DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  estimate     Estimate      @relation(fields: [estimateId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  payments     Payment[]
  changeOrders ChangeOrder[]
  messages     Message[]     @relation("ContractMessages")

  @@index([estimateId])
  @@index([customerId])
  @@index([status])
  @@index([stripeCustomerId])
}

model Payment {
  id                    String        @id @default(cuid())
  contractId            String
  type                  PaymentType
  method                PaymentMethod?
  amount                Float
  status                PaymentStatus @default(SCHEDULED)
  stripePaymentIntentId String?
  scheduledDate         DateTime?
  dueDate               DateTime?
  paidAt                DateTime?
  failedAt              DateTime?
  retryCount            Int           @default(0)
  createdAt             DateTime      @default(now())

  contract  Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  reminders PaymentReminder[]

  @@index([contractId])
  @@index([status])
  @@index([scheduledDate])
}

model PaymentReminder {
  id        String       @id @default(cuid())
  paymentId String
  type      ReminderType
  channel   MessageChannel
  sentAt    DateTime     @default(now())
  createdAt DateTime     @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model Message {
  id             String           @id @default(cuid())
  customerId     String
  estimateId     String?
  contractId     String?
  direction      MessageDirection @default(OUTBOUND)
  channel        MessageChannel
  content        String           @db.Text
  status         MessageStatus    @default(QUEUED)
  blooMessageId  String?
  sentAt         DateTime?
  createdAt      DateTime         @default(now())

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  estimate Estimate? @relation("EstimateMessages", fields: [estimateId], references: [id])
  contract Contract? @relation("ContractMessages", fields: [contractId], references: [id])

  @@index([customerId])
  @@index([estimateId])
  @@index([contractId])
  @@index([channel, status])
}

model PricingConfig {
  id          String          @id @default(cuid())
  key         String          @unique
  value       String
  category    PricingCategory
  label       String
  description String?         @db.Text
  updatedAt   DateTime        @updatedAt

  @@index([category])
  @@index([key])
}

model ChangeOrder {
  id                       String            @id @default(cuid())
  contractId               String
  description              String            @db.Text
  reason                   String?           @db.Text
  additionalSurfaces       Json?
  additionalMaterialCost   Float?
  additionalLaborCost      Float?
  markupPercent            Float?
  additionalPrice          Float?
  status                   ChangeOrderStatus @default(PROPOSED)
  customerApprovalMethod   ApprovalMethod?
  customerApprovalEvidence String?           @db.Text
  proposedAt               DateTime          @default(now())
  approvedAt               DateTime?
  completedAt              DateTime?
  createdAt                DateTime          @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([status])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  channel   MessageChannel
  subject   String?
  content   String   @db.Text
  variables Json?
  updatedAt DateTime @updatedAt

  @@index([key])
}

model CompanySettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model CustomerVerificationCode {
  id         String         @id @default(cuid())
  customerId String
  code       String
  channel    MessageChannel
  sentTo     String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime       @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([code])
  @@index([expiresAt])
}
