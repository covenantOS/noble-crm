{
  "name": "westchase-fieldservice",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n ui,api -c cyan,green \"vite\" \"wrangler dev --port 8787\"",
    "build": "vite build",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply westchase-fieldservice --local",
    "db:migrate:remote": "wrangler d1 migrations apply westchase-fieldservice --remote",
    "db:seed:local": "wrangler d1 execute westchase-fieldservice --local --file=src/server/seed.sql",
    "db:seed:remote": "wrangler d1 execute westchase-fieldservice --remote --file=src/server/seed.sql",
    "db:seed-brands:local": "wrangler d1 execute westchase-fieldservice --local --file=src/server/seed-brands.sql",
    "db:seed-brands:remote": "wrangler d1 execute westchase-fieldservice --remote --file=src/server/seed-brands.sql"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.18.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "lucide-preact": "^0.575.0",
    "preact": "^10.25.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@preact/preset-vite": "^2.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.106.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "workerd"
    ]
  }
}
